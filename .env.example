# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sales_management_db
DB_USER=root
DB_PASSWORD=password123
DB_POOL_LIMIT=10

# ============================================
# MICROSERVICES PORTS
# ============================================
USUARIOS_SERVICE_PORT=3001
PRODUCTOS_SERVICE_PORT=3002
VENTAS_SERVICE_PORT=3003
INVENTARIO_SERVICE_PORT=3004
FACTURACION_SERVICE_PORT=3005
NOTIFICACIONES_SERVICE_PORT=3006
FRONTEND_PORT=3000

# ============================================
# API GATEWAY
# ============================================
API_GATEWAY_HOST=localhost
API_GATEWAY_PORT=8000

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=your_secret_key_change_in_production
JWT_EXPIRATION=24h

# ============================================
# RABBITMQ CONFIGURATION (Optional)
# ============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:3000

# ============================================
# SESSION
# ============================================
SESSION_SECRET=session_secret_change_in_production
